# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=drug_ocr_db

# ===== JWT 配置 =====
# 【必须修改】使用以下命令生成随机强密钥（长度不能少于 32 字符）：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_WITH_YOUR_RANDOM_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Redis 配置（token 黑名单 + 登录限流）=====
# 启动前请确保 Redis 已运行: docker run -p 6379:6379 redis:7-alpine
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== 首次启动自动创建管理员 =====
# 仅在 users 表为空时生效。首次部署后建议立即在管理后台修改密码。
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin@2026!
INITIAL_ADMIN_REAL_NAME=系统管理员

# ===== 登录限流配置 =====
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15

# ===== 阿里云 OCR API 配置 =====
# 在阿里云控制台申请 RAM 子账号 AccessKey：
#   https://ram.console.aliyun.com/users
# 并为其授权 AliyunOCRFullAccess 或自定义最小权限策略。
ALIYUN_OCR_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_OCR_ACCESS_KEY_SECRET=your_access_key_secret_here

# ===== DeepSeek API（可选，用于后续 AI 辅助解析）=====
DEEPSEEK_API_KEY=

# ===== 文件上传配置 =====
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ===== 预警配置 =====
EXPIRY_WARNING_DAYS=30
LOW_STOCK_THRESHOLD=10

# ===== 阿里云 SMTP 邮件配置（用于忘记密码，P2 功能）=====
# 开通阿里云邮件推送服务后，在控制台获取 SMTP 账号和授权码
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=药品管理系统 <noreply@yourdomain.com>
SMTP_USE_SSL=true

# ===== 前端域名（邮件中的重置密码链接）=====
FRONTEND_URL=https://your-domain.com

# ===== 服务配置 =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
