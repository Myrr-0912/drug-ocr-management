# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=drug_ocr_db

# ===== JWT 配置 =====
# 【必须修改】使用以下命令生成随机强密钥（长度不能少于 32 字符）：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_WITH_YOUR_RANDOM_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Redis 配置（token 黑名单 + 登录限流）=====
# 启动前请确保 Redis 已运行: docker run -p 6379:6379 redis:7-alpine
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== 首次启动自动创建管理员 =====
# 仅在 users 表为空时生效。首次部署后建议立即在管理后台修改密码。
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin@2026!
INITIAL_ADMIN_REAL_NAME=系统管理员

# ===== 登录限流配置 =====
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15

# ===== 百度 OCR API 配置 =====
# 在百度智能云控制台申请: https://console.bce.baidu.com/ai/#/ai/ocr/app/list
BAIDU_OCR_API_KEY=your_api_key_here
BAIDU_OCR_SECRET_KEY=your_secret_key_here

# ===== 文件上传配置 =====
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ===== 预警配置 =====
EXPIRY_WARNING_DAYS=30
LOW_STOCK_THRESHOLD=10

# ===== 服务配置 =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
