# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=drug_ocr_db

# ===== JWT 配置 =====
# 生产环境必须替换为随机生成的强密钥: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 百度 OCR API 配置 =====
# 在百度智能云控制台申请: https://console.bce.baidu.com/ai/#/ai/ocr/app/list
BAIDU_OCR_API_KEY=your_api_key_here
BAIDU_OCR_SECRET_KEY=your_secret_key_here

# ===== 文件上传配置 =====
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ===== 预警配置 =====
# 提前多少天开始发出临期预警
EXPIRY_WARNING_DAYS=30
# 低库存预警阈值（件）
LOW_STOCK_THRESHOLD=10

# ===== 服务配置 =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
