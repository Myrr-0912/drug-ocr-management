# =============================================================================
# 生产 / Docker Compose 环境变量模板
# 使用方式：cp .env.production.example .env.production && 编辑全部 REPLACE_* 项
# =============================================================================

# ===== MySQL =====
# root 密码用于容器自身初始化；业务代码只使用 DB_USER/DB_PASSWORD
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD
DB_HOST=mysql
DB_PORT=3306
DB_USER=drug_app
DB_PASSWORD=REPLACE_WITH_STRONG_APP_PASSWORD
DB_NAME=drug_ocr_db

# ===== JWT =====
# 必须使用以下命令生成（≥32 字符）：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_KEY_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# ===== 首次启动自动创建管理员 =====
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
INITIAL_ADMIN_REAL_NAME=系统管理员

# ===== 登录限流 =====
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15

# ===== 阿里云 OCR =====
ALIYUN_OCR_ACCESS_KEY_ID=REPLACE_WITH_YOUR_ACCESS_KEY_ID
ALIYUN_OCR_ACCESS_KEY_SECRET=REPLACE_WITH_YOUR_ACCESS_KEY_SECRET

# ===== 阿里云 SMTP（忘记密码邮件）=====
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=noreply@your-domain.top
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM=药品管理系统 <noreply@your-domain.top>
SMTP_USE_SSL=true

# ===== 前端域名（邮件中的重置密码链接）=====
FRONTEND_URL=https://your-domain.top

# ===== 上传限制 =====
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ===== 预警 =====
EXPIRY_WARNING_DAYS=30
LOW_STOCK_THRESHOLD=10

# ===== 服务 =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# CORS：生产仅允许自己的域名；本地冒烟可临时加 http://localhost
CORS_ORIGINS=https://your-domain.top

# ===== DeepSeek（可选）=====
DEEPSEEK_API_KEY=
